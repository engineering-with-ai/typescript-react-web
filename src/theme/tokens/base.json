{
  "$name": "base",
  "$description": "Shared structural tokens across all themes",

  "spacing": {
    "$type": "dimension",
    "0": { "$value": "0px" },
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "32px" },
    "2xl": { "$value": "48px" }
  },

  "fontSize": {
    "$type": "dimension",
    "xs": { "$value": "12px" },
    "sm": { "$value": "14px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "20px" },
    "xl": { "$value": "24px" },
    "2xl": { "$value": "32px" },
    "3xl": { "$value": "48px" }
  },

  "fontWeight": {
    "$type": "fontWeight",
    "normal": { "$value": "400" },
    "medium": { "$value": "500" },
    "semibold": { "$value": "600" },
    "bold": { "$value": "700" },
    "black": { "$value": "900" }
  },

  "lineHeight": {
    "$type": "number",
    "tight": { "$value": "1.1" },
    "normal": { "$value": "1.5" },
    "relaxed": { "$value": "1.75" }
  },

  "duration": {
    "$type": "duration",
    "fast": { "$value": "100ms" },
    "normal": { "$value": "200ms" },
    "slow": { "$value": "400ms" }
  }
}
