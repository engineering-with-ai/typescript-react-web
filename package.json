{
  "name": "typescript-react-web",
  "version": "1.0.0-beta",
  "type": "module",
  "main": "src/main.tsx",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "depcheck": "depcheck --ignores=@types/*,@typescript-eslint/*,c8,eslint-plugin-react-hooks,eslint-plugin-react-refresh,identity-obj-proxy,jest-environment-jsdom,jest-transform-stub,jest-transformer-svg,react-native,react-native-web,react-native-svg,ts-jest,ts-node,tsconfig-paths,@tamagui/portal,@tamagui/polyfill-dev,gifted-charts-core,react-native-web-linear-gradient,buffer,react-native-screens,react-native-safe-area-context,react-router-dom",
    "format": "prettier --write src",
    "typecheck": "tsc ; eslint -c eslint-typecheck.config.mjs",
    "audit-src": "eslint -c eslint-security.config.mjs",
    "audit-packages": "npm audit --audit-level=moderate --format=json | grep -qE '\"severity\":\\s*\"(moderate|high|critical)\"' && exit 1 || exit 0",
    "lint": "eslint src --fix",
    "security": "npm run audit-src && npm run audit-packages",
    "checks": "npm run depcheck && npm run format && npm run typecheck && npm run security && npm run lint",
    "unit": "jest",
    "integration": "playwright test --reporter=line",
    "test": "npm run unit && npm run integration",
    "cover": "c8 npm run test",
    "review": "claude 'run code-reviewer agent against diff for quality and simplicity'",
    "commit": "npm run checks && npm run cover && npm run review && git add -A && git cz && git push"
  },
  "dependencies": {
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@tamagui/animations-css": "^1.142.0",
    "@tamagui/core": "^1.142.0",
    "@tamagui/dialog": "^1.142.0",
    "@tamagui/helpers-icon": "^1.142.0",
    "@tamagui/lucide-icons": "^1.142.0",
    "@tamagui/polyfill-dev": "^1.142.0",
    "@tamagui/popover": "^1.142.0",
    "@tamagui/portal": "^1.142.0",
    "@tamagui/switch": "^1.142.0",
    "@tamagui/toast": "^1.142.0",
    "@tamagui/tooltip": "^1.142.0",
    "@types/react-native-web": "^0.19.2",
    "buffer": "^6.0.3",
    "gifted-charts-core": "^0.1.72",
    "ip-address": "^10.0.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-native-gifted-charts": "^1.4.70",
    "react-native-safe-area-context": "^4.10.9",
    "react-native-screens": "^3.35.0",
    "react-native-svg": "^15.15.1",
    "react-native-web": "^0.21.1",
    "react-native-web-linear-gradient": "^1.1.2",
    "react-router-dom": "^7.11.0",
    "ts-pattern": "^5.0.0",
    "yaml": "^2.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@playwright/test": "^1.55.0",
    "@swc/core": "^1.13.5",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/ip-address": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "c8": "^10.1.2",
    "depcheck": "^1.4.7",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "48.11.0",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^15.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "jest-transform-stub": "^2.0.0",
    "jest-transformer-svg": "^2.1.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.1.2",
    "vite-plugin-react-native-web": "^2.2.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "cache": true,
    "cacheDirectory": ".jest-cache",
    "maxWorkers": "50%",
    "testMatch": [
      "<rootDir>/src/**/*.test.{js,ts,tsx}"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/jest-setup.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "@swc/jest",
        {
          "jsc": {
            "parser": {
              "syntax": "typescript",
              "tsx": true
            },
            "transform": {
              "react": {
                "runtime": "automatic"
              }
            }
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^react-native$": "react-native-web",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy",
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "jest-transform-stub",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@react-navigation|react-native|react-native-web|react-native-svg|react-native-screens|react-native-safe-area-context|@react-native)/)"
    ]
  },
  "c8": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.test.tsx",
      "**/*.styles.tsx"
    ],
    "reporter": [
      "text",
      "cobertura"
    ],
    "reports-dir": "coverage",
    "clean": true
  }
}
